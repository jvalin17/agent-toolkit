{
  "_comment": "Reference copy — same schema as templates/gates.json. Copy to project root as gates.json or use install.sh.",
  "_usage": "Set gate_mode, enforcement, and profile. Skill requirements come from profiles.<name>.",

  "gate_mode": "legacy",
  "enforcement": "warn",
  "profile": "minimal",
  "eval_threshold": 95,
  "profiles": {
    "minimal": {
      "commit_requires": ["precommit"],
      "push_requires": ["precommit"]
    },
    "standard": {
      "commit_requires": ["precommit"],
      "push_requires": ["precommit", "evaluate"]
    },
    "strict": {
      "commit_requires": ["precommit", "evaluate"],
      "push_requires": ["precommit", "evaluate", "reviewer"]
    },
    "paranoid": {
      "commit_requires": ["precommit", "evaluate"],
      "push_requires": ["precommit", "evaluate", "reviewer", "assess"]
    }
  }
}
