{
  "_comment": "Agent toolkit hooks — merged into ~/.claude/settings.json by install.sh",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__TOOLKIT_PATH__/hooks/precommit-gate.sh",
            "timeout": 5,
            "statusMessage": "Checking precommit gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__TOOLKIT_PATH__/hooks/post-commit-cleanup.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "__TOOLKIT_PATH__/hooks/precommit-passed.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
