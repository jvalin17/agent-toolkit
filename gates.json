{
  "gate_mode": "signed",
  "enforcement": "warn",
  "profile": "standard",
  "_comment": "This repo runs signed gate CI (agent-toolkit-gate.yml). Consumer template: templates/gates.json (legacy).",
  "eval_threshold": 95,
  "profiles": {
    "minimal": {
      "commit_requires": ["precommit"],
      "push_requires": ["precommit"]
    },
    "standard": {
      "commit_requires": ["precommit"],
      "push_requires": ["precommit", "evaluate"]
    },
    "strict": {
      "commit_requires": ["precommit", "evaluate"],
      "push_requires": ["precommit", "evaluate", "reviewer"]
    },
    "paranoid": {
      "commit_requires": ["precommit", "evaluate"],
      "push_requires": ["precommit", "evaluate", "reviewer", "assess"]
    }
  }
}
