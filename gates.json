{
  "gate_mode": "legacy",
  "enforcement": "block",
  "profile": "minimal",
  "mode": "normal",
  "eval_threshold": 95,
  "max_session_minutes": 0,
  "auto": false,
  "continue": false,
  "tdd": true,
  "tdd_mode": "remind",
  "skill_routing": true,
  "model": "auto",
  "gate_protect": true,
  "report_protect": true,
  "test_command": "python3 -m pytest tests/ -q",
  "lint_command": "python3 -m compileall -q gate hooks scripts tests",
  "profiles": {
    "minimal": {
      "commit_requires": [
        "precommit"
      ],
      "push_requires": []
    },
    "standard": {
      "commit_requires": [
        "precommit"
      ],
      "push_requires": [
        "evaluate"
      ]
    },
    "strict": {
      "commit_requires": [
        "precommit",
        "evaluate"
      ],
      "push_requires": [
        "evaluate",
        "reviewer"
      ]
    },
    "paranoid": {
      "commit_requires": [
        "precommit",
        "evaluate"
      ],
      "push_requires": [
        "evaluate",
        "reviewer",
        "assess"
      ]
    }
  }
}
